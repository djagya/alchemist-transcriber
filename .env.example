# Copy to `.env` in the directory you run commands from (usually the repo root).
# `transcribe` and `alchemist-check-enrollment` load `.env` via python-dotenv.
# Variables already set in your shell are not overwritten.

# --- Pipeline ---
# mlx (default) | torch — needs `uv sync --extra torch-pipeline` and HF token below
# ALCHEMIST_PIPELINE=mlx

# Required for torch pipeline (pyannote). Also: accept model terms on Hugging Face.
# Lines must start with HF_TOKEN= (no #). Example:
# HF_TOKEN=hf_...
# HUGGING_FACE_HUB_TOKEN=

# --- Whisper / language ---
# Default when this line is absent: Russian (ru). Use auto (or ALCHEMIST_LANGUAGE=) for auto-detect.
# ALCHEMIST_LANGUAGE=auto
# Default 2 if unset. Use `auto` for automatic speaker count.
# ALCHEMIST_NUM_SPEAKERS=2

# Optional ASR hint. Omit for built-in default (RU therapy: отношения, ПАВ/зависимость, жизненные темы, Тея, Лара, …).
# ALCHEMIST_INITIAL_PROMPT=

# --- MLX pipeline only (Hub repo id) ---
# ALCHEMIST_WHISPER_REPO=mlx-community/whisper-large-v3-mlx
# Smaller models use less RAM, e.g. mlx-community/whisper-medium-mlx
# 0 — segment-level timestamps only (lower MLX memory than default word-level)
# ALCHEMIST_WORD_TIMESTAMPS=1
# 1 — Whisper uses prior window text as prompt (try for names/context; may add repeat hallucinations / slower)
# Default off (omit or 0). Example: ALCHEMIST_MLX_CONDITION_ON_PREVIOUS_TEXT=1
# ALCHEMIST_MLX_CONDITION_ON_PREVIOUS_TEXT=0

# MLX Silero VAD prefilter (before mlx-whisper): pad speech segments (ms), keep last N s of raw audio for quiet outros
# ALCHEMIST_VAD_SPEECH_PAD_MS=200
# ALCHEMIST_VAD_TAIL_PRESERVE_SEC=25
# Set tail to 0 to disable passthrough of file ending
# Second Whisper pass on that tail (normalized WAV) to recover dropped closing lines (default on)
# ALCHEMIST_MLX_TAIL_RETRANSCRIBE=1

# Strip repeated 1-letter ASR junk (e.g. «в в в» on silence) in transcript blocks (default on)
# ALCHEMIST_SCRUB_REPEAT_TOKENS=1

# Post-ASR fixes: hyphen spacing (что-то, из-за), names/typos in src/transcript_fixes.py (default on)
# ALCHEMIST_ASR_TEXT_FIXES=1

# 1 — suppress ffmpeg warnings on stderr (same as: transcribe ... --quiet)
# ALCHEMIST_QUIET=1

# 1 — full YAML frontmatter with debug fields (same as: transcribe ... --verbose). Default is short header.
# ALCHEMIST_VERBOSE_META=1

# Optional mlx_whisper.transcribe decode thresholds (floats). Omit = library default.
# See mlx_whisper.transcribe docstring. Examples (uncomment to experiment):
# ALCHEMIST_MLX_NO_SPEECH_THRESHOLD=0.6
# ALCHEMIST_MLX_LOGPROB_THRESHOLD=-1.0
# ALCHEMIST_MLX_COMPRESSION_RATIO_THRESHOLD=2.4
# ALCHEMIST_MLX_HALLUCINATION_SILENCE_THRESHOLD=

# --- Torch pipeline only ---
# ALCHEMIST_OPENAI_WHISPER_MODEL=large-v3
# ALCHEMIST_WHISPER_DEVICE=auto
# ALCHEMIST_DIARIZATION_DEVICE=cpu

# --- Audio / enrollment ---
# Override enrollment directory, or `none` to disable ./enrollments
# ALCHEMIST_ENROLLMENT_DIR=

# 1 / true / yes — skip ffmpeg normalization (debug)
# ALCHEMIST_SKIP_FFMPEG_NORMALIZE=
